rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userPath() { return /databases/$(database)/documents/users/$(request.auth.uid); }
    function hasUserDoc() { return signedIn() && exists(userPath()); }
    function profile() { return get(userPath()).data; }
    function active() { return hasUserDoc() && profile().active != false; }
    function isAdmin() { return active() && profile().role == 'admin'; }
    function isTeacher() { return active() && profile().role in ['admin', 'teacher']; }
    function isAssistant() { return active() && profile().role == 'assistant'; }
    function isStaff() { return isTeacher() || isAssistant(); }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isStaff());
      allow create, update, delete: if false;
    }

    // Public website configuration must be stored separately from private settings.
    match /public_content/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /reviews/{reviewId} {
      allow get: if resource.data.approved == true || isStaff();
      allow list: if isStaff() || resource.data.approved == true;
      allow write: if false;
    }

    match /materials/{materialId} {
      allow get, list: if isStaff() || (resource.data.isPublic == true && resource.data.status == 'منشور');
      allow write: if false;
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if false;
    }

    // Every private/sensitive collection is readable only by authenticated staff.
    // All writes are intentionally denied to browsers; Admin SDK Cloud Functions bypass rules.
    match /students/{id} { allow read: if isStaff(); allow write: if false; }
    match /bookings/{id} { allow read: if isStaff(); allow write: if false; }
    match /groups/{id} { allow read: if isStaff(); allow write: if false; }
    match /tracks/{id} { allow read: if isStaff(); allow write: if false; }
    match /settings/{id} { allow read: if isStaff(); allow write: if false; }
    match /student_portal/{id} { allow read: if isStaff(); allow write: if false; }
    match /parent_portal/{id} { allow read: if isStaff(); allow write: if false; }
    match /attendance/{id} { allow read: if isStaff(); allow write: if false; }
    match /class_progress/{id} { allow read: if isStaff(); allow write: if false; }
    match /assignments/{id} { allow read: if isStaff(); allow write: if false; }
    match /homework_submissions/{id} { allow read: if isStaff(); allow write: if false; }
    match /upload_tickets/{id} { allow read, write: if false; }
    match /exams/{id} { allow read: if isStaff(); allow write: if false; }
    match /exam_attempts/{id} { allow read: if isStaff(); allow write: if false; }
    match /exam_submissions/{id} { allow read: if isStaff(); allow write: if false; }
    match /student_attempts/{id} { allow read: if isStaff(); allow write: if false; }
    match /practical_tasks/{id} { allow read: if isStaff(); allow write: if false; }
    match /practical_submissions/{id} { allow read: if isStaff(); allow write: if false; }
    match /practical_drafts/{id} { allow read: if isStaff(); allow write: if false; }
    match /onlineLectures/{id} { allow read: if isStaff(); allow write: if false; }
    match /onlineLectureAttendance/{id} { allow read: if isStaff(); allow write: if false; }
    match /grades/{id} { allow read: if isStaff(); allow write: if false; }
    match /payments/{id} { allow read: if isStaff(); allow write: if false; }
    match /files/{id} { allow read: if isStaff(); allow write: if false; }
    match /activityLog/{id} { allow read: if isStaff(); allow write: if false; }
    match /client_errors/{id} { allow read: if isStaff(); allow write: if false; }
    match /student_codes/{id} { allow read: if isStaff(); allow write: if false; }
    match /code_aliases/{id} { allow read: if isStaff(); allow write: if false; }
    match /booking_requests/{id} { allow read, write: if false; }
    match /rate_limits/{id} { allow read, write: if false; }
    match /public_cache/{id} { allow read, write: if false; }
    match /code_execution_runs/{id} { allow read, write: if false; }

    match /{document=**} { allow read, write: if false; }
  }
}
