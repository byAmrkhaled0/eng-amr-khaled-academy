# Region is fixed in code to europe-west1 so every callable uses one endpoint.
# Example: https://ce.judge0.com or your isolated self-hosted endpoint.
# Keep it empty until the execution service and its quotas are approved.
JUDGE0_BASE_URL=

# Leave blank for a self-hosted Judge0 instance without authentication.
# For a managed plan, use the header and value documented by the provider.
JUDGE0_API_KEY=
JUDGE0_API_KEY_HEADER=X-Auth-Token

# RapidAPI only. Leave blank for Judge0 CE/self-hosted.
JUDGE0_RAPIDAPI_HOST=

# Optional Firebase Storage bucket override.
STORAGE_BUCKET=

# Conservative execution limits. Judge0 may impose stricter plan limits.
CODE_MAX_BYTES=65536
STDIN_MAX_BYTES=16384
OUTPUT_MAX_BYTES=32768
CODE_CPU_SECONDS=5
CODE_WALL_SECONDS=10
CODE_MEMORY_KB=131072
