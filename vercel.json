{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install --ignore-scripts",
  "cleanUrls": false,
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "https://europe-west1-eng-amr-khaled-academy.cloudfunctions.net/getPlatformHealth"
    },
    {
      "source": "/api/booking/create",
      "destination": "https://europe-west1-eng-amr-khaled-academy.cloudfunctions.net/createBooking"
    },
    {
      "source": "/api/resources/student",
      "destination": "https://europe-west1-eng-amr-khaled-academy.cloudfunctions.net/getStudentResources"
    },
    {
      "source": "/api/code/getCodeLanguages",
      "destination": "https://europe-west1-eng-amr-khaled-academy.cloudfunctions.net/getCodeLanguages"
    },
    {
      "source": "/api/code/submitCodeExecution",
      "destination": "https://europe-west1-eng-amr-khaled-academy.cloudfunctions.net/submitCodeExecution"
    },
    {
      "source": "/api/code/getCodeExecutionResult",
      "destination": "https://europe-west1-eng-amr-khaled-academy.cloudfunctions.net/getCodeExecutionResult"
    }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/firebase-config.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://vercel.live; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://firebasestorage.googleapis.com https://storage.googleapis.com; media-src 'self' data: blob:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://*.cloudfunctions.net https://vercel.live wss://vercel.live; worker-src 'self' blob:; frame-src 'self' https://vercel.live; object-src 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ]
}
