{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(png|jpg|jpeg|svg|webp|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public,max-age=604800,must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "public,max-age=3600,must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(html|webmanifest|json)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "/service-worker.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/admin", "destination": "/teacher-login.html" },
      { "source": "/booking", "destination": "/booking.html" },
      { "source": "/student", "destination": "/student.html" },
      { "source": "/parent", "destination": "/parent.html" },
      { "source": "/practical", "destination": "/practical.html" },
      { "source": "/exams", "destination": "/exams.html" },
      { "source": "/materials", "destination": "/materials.html" },
      { "source": "/reviews", "destination": "/reviews.html" }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      ".env.example"
    ]
  }
}
